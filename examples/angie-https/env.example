
############################################################################
# Angie HTTPS example - environment variables
# Copy this file to .env and fill in your values
############################################################################

# Container image - local build by default, uncomment for GitHub registry
CONTAINER_IMAGE=domino-nrpc-proxy:angie
#CONTAINER_IMAGE=ghcr.io/nashcom/domino-nrpc-proxy:angie

# Public hostname - must have a DNS A record pointing to this machine
NGINX_SERVER_NAME=your.domain.example.com

# Contact email for Let's Encrypt account registration
NGINX_ACME_EMAIL=admin@example.com

# ACME server - staging by default, uncomment production when ready
NGINX_ACME_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
#NGINX_ACME_SERVER=https://acme-v02.api.letsencrypt.org/directory

# Log level (debug, info, notice, warn, error)
NGINX_LOG_LEVEL=notice
